# ─── Supabase ──────────────────────────────────────────────
# Public — safe to expose client-side.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Secret — server-side only. Never read from a client component.
SUPABASE_SERVICE_ROLE_KEY=

# ─── News ingestion ────────────────────────────────────────
# Free tiers are sufficient for the demo.
GNEWS_API_KEY=
NEWSDATA_API_KEY=

# ─── Optional / paid (add later when ready) ────────────────
# NEWSAPI_KEY=
# X_API_KEY=
# X_API_SECRET=
# X_BEARER_TOKEN=

# ─── AI synthesis (optional) ───────────────────────────────
# Used for LLM-based content extraction from raw sources.
# Leave blank until you're ready to enable AI synthesis.
# ANTHROPIC_API_KEY=
